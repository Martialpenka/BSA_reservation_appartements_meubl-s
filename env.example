# ======================================================
# BSA – Gestion d'appartements meublés
# .env.example — Copie ce fichier en .env et remplis
#                les valeurs avant de lancer le projet
# ======================================================

# ── Base de données PostgreSQL ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bsa_db
DB_USER=postgres
DB_PASSWORD=

# ── Serveur Node.js ─────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT (Authentification) ───────────────────────────
# Génère une clé secrète forte :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ── Backend Java (si séparé) ─────────────────────────
JAVA_PORT=8080
JAVA_DB_URL=jdbc:postgresql://localhost:5432/bsa_db
JAVA_DB_USER=postgres
JAVA_DB_PASSWORD=

# ── Apache / Serveur (optionnel) ─────────────────────
APP_URL=http://localhost:3000

# ── Email (optionnel – notifications) ────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
